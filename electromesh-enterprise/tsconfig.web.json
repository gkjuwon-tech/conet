{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@design/*": ["../design/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/renderer/**/*", "src/preload/index.d.ts", "../design/**/*.ts", "../design/**/*.tsx"]
}
